# =============================================================================
# Environment Configuration
# =============================================================================
#
# This file documents all environment variables used by the application.
# Variables are categorized by which component requires them:
#
# [CLI]  - Required by CLI commands (sb add, sb queue, sb search, sb stats)
# [BOT]  - Required only by the Discord bot
# [BOTH] - Required by both CLI and bot
#
# The CLI operates independently of Discord and does not require DISCORD_*
# environment variables.

# =============================================================================
# Discord Bot Configuration [BOT]
# =============================================================================
# These variables are only required when running the Discord bot.
# The CLI commands (sb add, sb queue, etc.) do NOT require these.

DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id

# =============================================================================
# Database Configuration [BOTH]
# =============================================================================
# Required by both CLI and bot for database operations.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/discord_links

# =============================================================================
# LLM Configuration [BOTH]
# =============================================================================
# Required for the `sb add` command and bot link ingestion.
# Used for generating summaries and embeddings.

LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=your-model-name
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_MS=250

# Optional: Separate model for embeddings (uses LLM_MODEL if not set) [BOTH]
# LLM_EMBEDDING_MODEL=embed-model-name

# Optional: Embedding batch size (default: 2048) [BOTH]
# LLM_EMBEDDING_BATCH_SIZE=2048

# Optional: Max characters per embed chunk (default: 1100) [BOTH]
# LLM_EMBEDDING_MAX_CHARS=1100

# Optional: Embedding dimensions (default: 1024) [BOTH]
# LLM_EMBEDDING_DIM=1024

# =============================================================================
# Ingestion Configuration [BOTH]
# =============================================================================
# Reaction emojis shown by bot on Discord messages (CLI ignores these)

INGEST_SUCCESS_REACTION=✅
INGEST_FAILURE_REACTION=⚠️
INGEST_UPDATE_REACTION=🔄

# =============================================================================
# Logging Configuration [BOTH]
# =============================================================================
# Valid values: debug, info, warn, error

LOG_LEVEL=info

# =============================================================================
# YouTube Data API Configuration [BOTH]
# =============================================================================
# Required for YouTube video metadata and caption fetching.
# Get API key from https://console.cloud.google.com/apis/credentials

YOUTUBE_API_KEY=your_youtube_api_key_here

# Language code for preferred captions (default: en) [BOTH]
YOUTUBE_CAPTION_LANGUAGE=en

# Enable/disable YouTube caption fetching (default: true) [BOTH]
ENABLE_YOUTUBE_CAPTIONS=true

# =============================================================================
# Bot-Specific Configuration [BOT]
# =============================================================================
# These variables are only used by the Discord bot.

# File URL Configuration
# Comma-separated list of Discord user IDs allowed to submit file:// URLs
# Only applies to Discord messages; CLI commands have no restrictions
# Example: ALLOWED_FILE_URL_USERS=123456789012345678,987654321098765432
ALLOWED_FILE_URL_USERS=

# Backfill queue configuration
# Interval between backfill queue processing runs in milliseconds (default: 3600000 = 1 hour)
BACKFILL_INTERVAL_MS=3600000

# Maximum retry attempts for backfill items (default: 3)
MAX_BACKFILL_ATTEMPTS=3

# Startup recovery configuration
# Maximum messages to scan on startup for recovery (0 to disable)
STARTUP_RECOVERY_MAX_MESSAGES=1000
