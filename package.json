{
  "name": "discord-link-aggregation-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot for indexing and retrieving shared links",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.6.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
