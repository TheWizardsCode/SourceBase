{
  "name": "discord-link-aggregation-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot for indexing and retrieving shared links",
  "type": "module",
  "bin": {
    "sb": "./dist/src/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx src/db/migrate.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "./scripts/start-db.sh && node dist/src/index.js",
    "start:dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.0.20",
    "discord.js": "^13.17.1",
    "dotenv": "^16.6.1",
    "html-to-text": "^6.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
